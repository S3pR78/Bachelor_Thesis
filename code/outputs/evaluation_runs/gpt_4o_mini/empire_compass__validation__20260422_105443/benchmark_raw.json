      "question": "How many reported Hypotheses does each paper have?",
      "gold_query": "SELECT ?paper ?paperLabel (COUNT(DISTINCT ?hypothesis) AS ?number_of_reported_hypotheses)\nWHERE {\n\n    ?paper orkgp:P31 ?contribution .\n\n    OPTIONAL { ?paper rdfs:label ?paperLabel . }\n\n    ?contribution a orkgc:C27001 ;\n                  orkgp:P135046 ?venue ;\n                  orkgp:P15124 ?data_analysis .\n\n    ?venue rdfs:label ?venue_name .\n\n    ?data_analysis rdfs:label ?da_label ;\n                   orkgp:P56043 ?inferential_statistics .\n\n    ?inferential_statistics orkgp:P30001 ?hypothesis .\n\n    FILTER(?da_label != \"no analysis\"^^xsd:string)\n    FILTER(?venue_name = \"IEEE International Requirements Engineering Conference\"^^xsd:string)\n}\nGROUP BY ?paper ?paperLabel\nORDER BY DESC(?number_of_reported_hypotheses) ?paperLabel",
