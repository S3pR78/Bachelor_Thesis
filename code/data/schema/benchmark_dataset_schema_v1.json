{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Benchmark dataset entry",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "source_dataset",
    "source_id",
    "family",
    "split",
    "language",
    "question"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-[0-9]{4,}$",
      "description": "Globally unique entry id, e.g. nlp4re-0042"
    },
    "source_dataset": {
      "type": "string",
      "enum": ["EmpiRE_Compass", "usw."],
      "description": "Original source collection of the entry"
    },
    "source_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Original identifier in the source dataset"
    },
    "family": {
      "type": "string",
      "enum": ["nlp4re", "empirical_research_practice"],
      "description": "Template family / benchmark family"
    },
    "split": {
      "type": "string",
      "enum": ["train", "validation", "test"],
      "description": "Dataset split assignment"
    },
    "language": {
      "type": "string",
      "enum": ["en", "de"],
      "description": "Language of the question"
    },
    "question": {
      "type": "string",
      "minLength": 1,
      "description": "Primary natural-language question used as the main benchmark input."
    },
    "paraphrased_questions": {
      "type": "array",
      "description": "Optional alternative phrasings of the main question.",
      "default": [],
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}