{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Benchmark dataset entry",
  "type": "object",
  "required": ["id", "family", "split", "language", "source"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-[0-9]{4,}$",
      "description": "Globally unique entry id, e.g. nlp4re-0042"
    },
    "family": {
      "type": "string",
      "enum": ["nlp4re", "empirical_research_practice"],
      "description": "Template family / benchmark family"
    },
    "split": {
      "type": "string",
      "enum": ["train", "validation", "test"],
      "description": "Dataset split assignment"
    },
    "language": {
      "type": "string",
      "enum": ["en", "de"],
      "description": "Language of the natural-language question"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "reviewed", "approved", "rejected"],
      "description": "Optional curation status"
    },
    "source": {
      "type": "object",
      "required": ["dataset", "record_id", "origin"],
      "additionalProperties": false,
      "properties": {
        "dataset": {
          "type": "string",
          "enum": ["EmpiRE_Compass", "usw."],
          "description": "Original source collection"
        },
        "record_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]+$",
          "description": "Original source-side identifier"
        },
        "origin": {
          "type": "string",
          "enum": ["human", "generated", "converted"],
          "description": "How the entry originally entered the pipeline"
        }
      }
    }
  },
  "additionalProperties": true
}