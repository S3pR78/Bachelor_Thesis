{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Benchmark dataset entry",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "source_dataset",
    "source_id",
    "family",
    "split",
    "language",
    "question",
    "gold_sparql"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-[0-9]{4,}$",
      "description": "Globally unique entry id, e.g. nlp4re-0042"
    },
    "source_dataset": {
      "type": "string",
      "enum": ["EmpiRE_Compass", "usw."],
      "description": "Original source collection of the entry"
    },
    "source_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Original identifier in the source dataset"
    },
    "family": {
      "type": "string",
      "enum": ["nlp4re", "empirical_research_practice"],
      "description": "Template family / benchmark family"
    },
    "split": {
      "type": "string",
      "enum": ["train", "validation", "test"],
      "description": "Dataset split assignment"
    },
    "language": {
      "type": "string",
      "enum": ["en", "de"],
      "description": "Language of the question"
    },
    "question": {
      "type": "string",
      "minLength": 1,
      "description": "Primary natural-language question used as the main benchmark input."
    },
    "paraphrased_questions": {
      "type": "array",
      "description": "Optional alternative phrasings of the main question.",
      "default": [],
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "gold_sparql": {
      "type": "string",
      "minLength": 1,
      "description": "Final gold SPARQL query for the entry."
    },
    "canonical_sparql": {
      "type": "string",
      "minLength": 1,
      "description": "Optional canonical schema-level SPARQL query with placeholders instead of final ORKG-specific identifiers."
    },
    "canonical_to_gold_mapping": {
      "type": "object",
      "description": "Optional mapping from canonical placeholders to final ORKG identifiers or literals.",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^__[A-Z0-9_]+__$"
      },
      "additionalProperties": {
        "type": "object",
        "required": ["kind", "value"],
        "additionalProperties": false,
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["predicate", "class", "resource", "literal"]
          },
          "value": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "template_sections": {
      "type": "array",
      "description": "Optional list of template sections involved in the question.",
      "uniqueItems": true,
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "query_type": {
      "type": "string",
      "enum": ["factoid", "non_factoid"],
      "description": "High-level question category."
    },
    "special_types": {
      "type": "array",
      "description": "Optional list of more specific question/query characteristics.",
      "default": [],
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "lookup",
          "typed_lookup",
          "multi_hop",
          "count",
          "aggregation",
          "ranking",
          "superlative",
          "temporal",
          "boolean",
          "negation",
          "missing_info",
          "comparison",
          "multi_intent",
          "string_operation"
        ]
      }
    },
    "answer_type": {
      "type": "string",
      "enum": ["resource", "string", "number", "boolean", "date", "list", "mixed"],
      "description": "Expected answer type of the query."
    },
    "query_shape": {
      "type": "string",
      "enum": ["edge", "chain", "star", "tree", "cycle", "forest", "other"],
      "description": "Structural shape of the SPARQL query."
    },
    "number_of_patterns": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of triple patterns in the gold SPARQL query."
    },
    "query_components": {
      "type": "array",
      "description": "SPARQL operators and structural components used in the gold query.",
      "default": [],
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "SELECT",
          "ASK",
          "COUNT",
          "FILTER",
          "REGEX",
          "STR",
          "ORDER_BY",
          "GROUP_BY",
          "HAVING",
          "LIMIT",
          "OPTIONAL",
          "UNION",
          "NOT_EXISTS",
          "MIN",
          "MAX",
          "AVG"
        ]
      }
    },
    "complexity_level": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "description": "Coarse human-readable complexity label."
    },
    "ambiguity_risk": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "description": "Estimated ambiguity risk of the question wording."
    },
    "lexical_gap_risk": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "description": "Estimated lexical gap between the question wording and schema vocabulary."
    },
    "hallucination_risk": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "description": "Estimated risk that generation may hallucinate schema elements or identifiers."
    }
  }
}