  "global_generation_rules": {
    "language": "en",
    "deduplicate_against_existing_questions": true,
    "deduplicate_against_existing_question_sparql_pairs": true,
    "preserve_schema_faithfulness": true,
    "do_not_invent_predicates_or_classes": true,
    "prefer_template-grounded_generation": true
  },
  "validation_pipeline": {
    "required_checks_for_all_candidates": [
      "valid JSON structure",
      "all metadata fields populated",
      "SPARQL syntax sanity check",
      "family-source_dataset consistency",
      "query_components match gold_sparql",
      "answer_type matches expected answer shape",
      "duplicate detection against existing dataset",
      "basic endpoint execution where feasible"
    ],
    "required_checks_for_benchmark_acceptance": [
      "manual review of question wording",
      "manual review of gold_sparql correctness",
      "manual review of metadata correctness",
      "review_status must become approved",
      "gold_status must become final"
    ]
  },
  "post_phase_decisions": {
    "after_generation": [
      "review all 85 candidates",
      "keep strongest 55 to 85 depending on quality",
      "freeze accepted additions for benchmark selection",
      "move remaining valid candidates into fine-tuning candidate pool"
    ],
    "split_policy_note": "do not assign final train/validation/test until deduplication and benchmark freeze are complete"
  }
