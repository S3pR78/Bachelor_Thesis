    {
      "id": "nlp4re_pgmr_lite_nested_paths_initial",
      "family": "nlp4re",
      "mode": "pgmr_lite",
      "category": "nested_path",
      "title": "Use full nested NLP4RE paths",
      "content": "For nested NLP4RE fields, first bind the parent node from ?contribution and then bind the requested child field. Examples: evaluation questions use contribution -> evaluation -> metric/baseline/validation; NLP task questions use contribution -> NLP task -> input/output/task type; dataset questions use contribution -> NLP dataset -> dataset field.",
      "bullet_type": "rule",
      "priority": 115,
      "enabled": true,
      "avoid": "Do not skip parent nodes when asking for nested fields.",
      "positive_pattern": "?contribution pgmr:evaluation ?evaluation . ?evaluation pgmr:evaluation_metric ?answer .",
      "applicability": "NLP4RE nested-field questions.",
      "source": {
        "type": "manual_clean_base_initialization"
      },
