    {
      "id": "nlp4re_pgmr_lite_contribution_pattern_initial",
      "family": "nlp4re",
      "mode": "pgmr_lite",
      "category": "contribution_pattern",
      "title": "Use NLP4RE contribution pattern",
      "content": "Always connect the paper to the contribution with ?paper pgmr:has_contribution ?contribution . and type the contribution as pgmrc:nlp4re_contribution . Attach NLP4RE template fields to ?contribution or to properly bound nested nodes.",
      "bullet_type": "rule",
      "priority": 120,
      "enabled": true,
      "avoid": "Do not attach NLP4RE template fields directly to ?paper except publication year.",
      "positive_pattern": "?paper pgmr:has_contribution ?contribution . ?contribution a pgmrc:nlp4re_contribution .",
      "applicability": "All NLP4RE PGMR-lite queries.",
      "source": {
        "type": "manual_clean_base_initialization"
      },
      "evidence_item_ids": [],
      "helpful_count": 0,
